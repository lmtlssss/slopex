+struct RolloutArchive {
+    path: PathBuf,
+    items: Vec<RolloutItem>,
+}
+
+pub(crate) fn obsidian_graph_root(config: &Config) -> &Path {
+    config.experimental_obsidian_graph_root.as_path()
+}
+
+pub(crate) fn thread_graph_root(config: &Config, thread_id: &ThreadId) -> PathBuf {
+    obsidian_graph_root(config).join(thread_id.to_string())
+}
+
+pub(crate) fn graph_continuity_instruction(config: &Config, thread_id: &ThreadId) -> String {
+    let thread_root = thread_graph_root(config, thread_id);
+    let index_path = thread_root.join("index.md");
+    format!(
+        concat!(
+            "Continuity mode is reset-based, not summary-based.\n",
+            "When the context window fills, Codex exports the prior thread into an Obsidian-style graph and clears live history instead of carrying forward a compacted summary capsule.\n",
+            "If older thread continuity matters, prefer the filesystem graph at `{}`.\n",
+            "Start with `{}`, then consult `timeline/`, `themes/`, and the newest `segments/` entries.\n",
+            "Treat the current workspace state and these graph notes as canonical over vague recollection."
+        ),
+        thread_root.display(),
+        index_path.display(),
+    )
+}
+
+pub(crate) async fn run_auto_reset_compact(
+    sess: Arc<Session>,
+    turn_context: Arc<TurnContext>,
+    initial_context_injection: InitialContextInjection,
+) -> CodexResult<()> {
+    let compaction_item = TurnItem::ContextCompaction(ContextCompactionItem::new());
+    sess.emit_turn_item_started(&turn_context, &compaction_item)
+        .await;
+
+    let history_snapshot = sess.clone_history().await;
+    let history_items = history_snapshot.raw_items();
+    let thread_root = thread_graph_root(&turn_context.config, &sess.conversation_id);
+    let rollout_archive = load_rollout_archive(sess.as_ref()).await;
+    let export_result = export_graph_segment(
+        &thread_root,
+        &sess.conversation_id,
+        &turn_context.sub_id,
+        initial_context_injection,
+        history_items,
+        rollout_archive.as_ref(),
+    );
+
+    let mut exported_segment_root = None;
+    match export_result {
+        Ok(segment_root) => {
+            exported_segment_root = Some(segment_root);
+        }
+        Err(err) => {
+            warn!(
+                thread_id = %sess.conversation_id,
+                turn_id = %turn_context.sub_id,
+                graph_root = %thread_root.display(),
+                "failed to export reset continuity graph: {err}"
+            );
+            sess.notify_background_event(
+                &turn_context,
+                format!(
+                    "Context reset ran, but continuity export to {} failed: {err}",
+                    thread_root.display()
+                ),
+            )
+            .await;
+        }
+    }
+
+    if let Some(segment_root) = exported_segment_root.as_ref()
+        && turn_context
+            .config
+            .experimental_obsidian_graph_background_agent
+    {
+        spawn_graph_organizer_agent(
+            &sess.services.agent_control,
+            turn_context.as_ref(),
+            thread_root.clone(),
+            segment_root.clone(),
+        );
+    }
+
+    let (new_history, reference_context_item) = build_reset_replacement_history(
+        sess.as_ref(),
+        turn_context.as_ref(),
+        initial_context_injection,
+    )
+    .await;
+    let compacted_item = CompactedItem {
+        message: format!(
+            "Context reset. Continuity exported to {}",
+            thread_root.display()
+        ),
+        replacement_history: Some(new_history.clone()),
+    };
+
+    sess.replace_compacted_history(new_history, reference_context_item, compacted_item)
+        .await;
+    sess.recompute_token_usage(&turn_context).await;
+    sess.emit_turn_item_completed(&turn_context, compaction_item)
+        .await;
+
+    let export_message = exported_segment_root.as_ref().map_or_else(
+        || {
+            format!(
+                "Reset live context without a continuity summary capsule. Intended graph root: {}.",
+                thread_root.display()
+            )
+        },
+        |segment_root| {
+            format!(
+                "Reset live context after exporting continuity to {}.",
+                segment_root.display()
+            )
+        },
+    );
+    sess.notify_background_event(&turn_context, export_message)
+        .await;
+    Ok(())
+}
+
+async fn build_reset_replacement_history(
+    sess: &Session,
+    turn_context: &TurnContext,
+    initial_context_injection: InitialContextInjection,
+) -> (
+    Vec<ResponseItem>,
+    Option<codex_protocol::protocol::TurnContextItem>,
+) {
+    match initial_context_injection {
+        InitialContextInjection::DoNotInject => (Vec::new(), None),
+        InitialContextInjection::BeforeLastUserMessage => {
+            let initial_context = sess.build_initial_context(turn_context).await;
+            (initial_context, Some(turn_context.to_turn_context_item()))
+        }
+    }
+}
+
+fn export_graph_segment(
+    thread_root: &Path,
+    thread_id: &ThreadId,
+    turn_id: &str,
+    initial_context_injection: InitialContextInjection,
+    history_items: &[ResponseItem],
+    rollout_archive: Option<&RolloutArchive>,
+) -> std::io::Result<PathBuf> {
+    let timestamp = Utc::now();
+    let segment_id = format!(
+        "{}-{}",
+        timestamp.format("%Y%m%dT%H%M%SZ"),
+        sanitize_path_component(turn_id)
+    );
+    let segments_root = thread_root.join("segments");
+    let segment_root = segments_root.join(&segment_id);
+    let messages_root = segment_root.join("messages");
+    let timeline_root = thread_root.join("timeline");
+    let themes_root = thread_root.join("themes");
+
+    fs::create_dir_all(&messages_root)?;
+    fs::create_dir_all(&timeline_root)?;
+    fs::create_dir_all(&themes_root)?;
+
+    let metadata = json!({
+        "thread_id": thread_id.to_string(),
+        "turn_id": turn_id,
+        "captured_at_utc": timestamp.to_rfc3339(),
+        "reset_mode": "context_reset",
+        "initial_context_injection": match initial_context_injection {
+            InitialContextInjection::BeforeLastUserMessage => "before_last_user_message",
+            InitialContextInjection::DoNotInject => "do_not_inject",
+        },
+        "raw_item_count": history_items.len(),
+        "rollout_archive_path": rollout_archive.map(|archive| archive.path.display().to_string()),
+        "rollout_item_count": rollout_archive.map(|archive| archive.items.len()),
+    });
+    fs::write(
+        segment_root.join("thread_meta.json"),
+        serde_json::to_vec_pretty(&metadata)?,
+    )?;
+    fs::write(
+        segment_root.join("history.json"),
+        serde_json::to_vec_pretty(history_items)?,
+    )?;
+    if let Some(rollout_archive) = rollout_archive {
+        fs::write(
+            segment_root.join("rollout_items.json"),
+            serde_json::to_vec_pretty(&rollout_archive.items)?,
+        )?;
+        fs::write(
+            segment_root.join("rollout_path.txt"),
+            format!("{}\n", rollout_archive.path.display()),
+        )?;
+    }
+
+    let graph_items = graph_items_from_history(history_items);
+    for (index, graph_item) in graph_items.iter().enumerate() {
+        let file_name = format!("{:04}-{}.md", index + 1, graph_item.slug);
+        fs::write(
+            messages_root.join(file_name),
+            render_graph_item_markdown(thread_id, &segment_id, index + 1, graph_item),
+        )?;
+    }
+
+    fs::write(
+        segment_root.join("segment.md"),
+        render_segment_markdown(
+            thread_id,
+            turn_id,
+            &segment_id,
+            &graph_items,
+            rollout_archive,
+        ),
+    )?;
+
+    ensure_placeholder_notes(thread_root, thread_id)?;
+    write_thread_index(thread_root, thread_id)?;
+    Ok(segment_root)
+}
+
+#[derive(Clone)]
+struct GraphItem {
+    title: String,
+    slug: String,
+    body: String,
+}
+
+fn graph_items_from_history(history_items: &[ResponseItem]) -> Vec<GraphItem> {
+    history_items
+        .iter()
+        .filter_map(graph_item_from_response_item)
+        .collect()
+}
+
+fn graph_item_from_response_item(item: &ResponseItem) -> Option<GraphItem> {
+    match item {
+        ResponseItem::Message { role, content, .. } => {
+            if role == "developer" {
+                return None;
+            }
+            let text = content_items_to_text(content)?;
+            let trimmed = text.trim();
+            if trimmed.is_empty() {
+                return None;
+            }
+            Some(GraphItem {
+                title: role.to_string(),
+                slug: sanitize_path_component(role),
+                body: trimmed.to_string(),
+            })
+        }
+        ResponseItem::FunctionCall {
+            name, arguments, ..
+        } => Some(GraphItem {
+            title: format!("tool call {name}"),
+            slug: format!("tool-call-{}", sanitize_path_component(name)),
+            body: format!("Arguments:\n```json\n{}\n```", pretty_json(arguments)),
+        }),
+        ResponseItem::FunctionCallOutput { call_id, output } => Some(GraphItem {
+            title: format!("tool output {call_id}"),
+            slug: "tool-output".to_string(),
+            body: output.body.to_text().unwrap_or_else(|| {
+                format!(
+                    "Structured output:\n```json\n{}\n```",
+                    serde_json::to_string_pretty(item).unwrap_or_else(|_| "{}".to_string())
+                )
+            }),
+        }),
+        ResponseItem::CustomToolCall { name, input, .. } => Some(GraphItem {
+            title: format!("custom tool call {name}"),
+            slug: format!("custom-tool-call-{}", sanitize_path_component(name)),
+            body: format!("Input:\n```text\n{input}\n```"),
+        }),
+        ResponseItem::CustomToolCallOutput { name, output, .. } => Some(GraphItem {
+            title: format!(
+                "custom tool output {}",
+                name.as_deref().unwrap_or("unnamed")
+            ),
+            slug: "custom-tool-output".to_string(),
+            body: output.body.to_text().unwrap_or_else(|| {
+                format!(
+                    "Structured output:\n```json\n{}\n```",
+                    serde_json::to_string_pretty(item).unwrap_or_else(|_| "{}".to_string())
+                )
+            }),
+        }),
+        ResponseItem::LocalShellCall { .. }
+        | ResponseItem::ToolSearchCall { .. }
+        | ResponseItem::ToolSearchOutput { .. }
+        | ResponseItem::WebSearchCall { .. }
+        | ResponseItem::ImageGenerationCall { .. } => Some(GraphItem {
+            title: response_item_label(item).to_string(),
+            slug: sanitize_path_component(response_item_label(item)),
+            body: format!(
+                "```json\n{}\n```",
+                serde_json::to_string_pretty(item).unwrap_or_else(|_| "{}".to_string())
+            ),
+        }),
+        ResponseItem::Reasoning { .. }
+        | ResponseItem::GhostSnapshot { .. }
+        | ResponseItem::Compaction { .. }
+        | ResponseItem::Other => None,
+    }
+}
+
+fn render_graph_item_markdown(
+    thread_id: &ThreadId,
+    segment_id: &str,
+    sequence: usize,
+    graph_item: &GraphItem,
+) -> String {
+    format!(
+        concat!(
+            "---\n",
+            "thread_id: {}\n",
+            "segment_id: {}\n",
+            "sequence: {}\n",
+            "title: {}\n",
+            "---\n\n",
+            "# {:04} {}\n\n",
+            "[[../segment]]\n\n",
+            "{}\n"
+        ),
+        thread_id,
+        segment_id,
+        sequence,
+        graph_item.title,
+        sequence,
+        graph_item.title,
+        graph_item.body,
+    )
+}
+
+fn render_segment_markdown(
+    thread_id: &ThreadId,
+    turn_id: &str,
+    segment_id: &str,
+    graph_items: &[GraphItem],
+    rollout_archive: Option<&RolloutArchive>,
+) -> String {
+    let mut body = format!(
+        concat!(
+            "# Segment {}\n\n",
+            "- Thread: `{}`\n",
+            "- Turn: `{}`\n",
+            "- Raw history: `history.json`\n\n",
+            "{}",
+            "## Notes\n"
+        ),
+        segment_id,
+        thread_id,
+        turn_id,
+        rollout_archive_section(rollout_archive)
+    );
+    if graph_items.is_empty() {
+        body.push_str("- No normalized graph items were extracted from this segment.\n");
+    } else {
+        for (index, graph_item) in graph_items.iter().enumerate() {
+            body.push_str(&format!(
+                "- [[messages/{:04}-{}|{:04} {}]]\n",
+                index + 1,
+                graph_item.slug,
+                index + 1,
+                graph_item.title
+            ));
+        }
+    }
+    body
+}
+
+fn ensure_placeholder_notes(thread_root: &Path, thread_id: &ThreadId) -> std::io::Result<()> {
+    let overview_path = thread_root.join("timeline").join("overview.md");
+    if !overview_path.exists() {
+        fs::write(
+            overview_path,
+            format!(
+                "# Timeline {thread_id}\n\n- Background organizer updates this file with chronological continuity.\n"
+            ),
+        )?;
+    }
+
+    let themes_index_path = thread_root.join("themes").join("index.md");
+    if !themes_index_path.exists() {
+        fs::write(
+            themes_index_path,
+            format!(
+                "# Themes {thread_id}\n\n- Background organizer updates this index with durable semantic themes.\n"
+            ),
+        )?;
+    }
+    Ok(())
+}
+
+fn write_thread_index(thread_root: &Path, thread_id: &ThreadId) -> std::io::Result<()> {
+    let segments_root = thread_root.join("segments");
+    let mut segment_names = fs::read_dir(&segments_root)?
+        .filter_map(std::result::Result::ok)
+        .filter_map(|entry| {
+            entry
+                .file_type()
+                .ok()
+                .filter(std::fs::FileType::is_dir)
+                .map(|_| entry.file_name().to_string_lossy().into_owned())
+        })
+        .collect::<Vec<_>>();
+    segment_names.sort();
+    segment_names.reverse();
+
+    let mut body = format!(
+        "# Thread {thread_id}\n\n## Continuity Entry Points\n- [[timeline/overview]]\n- [[themes/index]]\n\n## Segments\n"
+    );
+    if segment_names.is_empty() {
+        body.push_str("- No segments exported yet.\n");
+    } else {
+        for segment_name in segment_names {
+            body.push_str(&format!(
+                "- [[segments/{segment_name}/segment|{segment_name}]]\n"
+            ));
+        }
+    }
+    fs::write(thread_root.join("index.md"), body)
+}
+
+fn spawn_graph_organizer_agent(
+    agent_control: &AgentControl,
+    turn_context: &TurnContext,
+    thread_root: PathBuf,
+    segment_root: PathBuf,
+) {
+    let Ok(thread_root_abs) = AbsolutePathBuf::from_absolute_path(&thread_root) else {
+        warn!(
+            graph_root = %thread_root.display(),
+            "failed to resolve graph root for organizer agent"
+        );
+        return;
+    };
+
+    let mut agent_config = turn_context.config.as_ref().clone();
+    agent_config.cwd = thread_root_abs.clone();
+    agent_config.model_auto_compact_token_limit = Some(i64::MAX);
+    agent_config.experimental_auto_compact_mode = AutoCompactMode::Summarize;
+    agent_config.experimental_obsidian_graph_background_agent = false;
+    agent_config.permissions.approval_policy = Constrained::allow_only(AskForApproval::Never);
+    agent_config.permissions.network = None;
+    agent_config.web_search_mode = Constrained::allow_only(WebSearchMode::Disabled);
+
+    let sandbox_policy = SandboxPolicy::WorkspaceWrite {
+        writable_roots: vec![thread_root_abs],
+        read_only_access: Default::default(),
+        network_access: false,
+        exclude_tmpdir_env_var: false,
+        exclude_slash_tmp: false,
+    };
+    agent_config.permissions.sandbox_policy = Constrained::allow_only(sandbox_policy.clone());
+    agent_config.permissions.file_system_sandbox_policy =
+        FileSystemSandboxPolicy::from(&sandbox_policy);
+    agent_config.permissions.network_sandbox_policy = NetworkSandboxPolicy::from(&sandbox_policy);
+
+    let _ = agent_config.features.disable(Feature::SpawnCsv);
+    let _ = agent_config.features.disable(Feature::Collab);
+    let _ = agent_config.features.disable(Feature::MemoryTool);
+
+    let prompt = vec![UserInput::Text {
+        text: build_graph_organizer_prompt(&thread_root, &segment_root),
+        text_elements: Vec::new(),
+    }];
+    let source = SessionSource::SubAgent(SubAgentSource::Other("obsidian_graph_reset".to_string()));
+    let agent_control = agent_control.clone();
+    tokio::spawn(async move {
+        if let Err(err) = agent_control
+            .spawn_agent(agent_config, prompt, Some(source))
+            .await
+        {
+            warn!(
+                graph_root = %thread_root.display(),
+                latest_segment = %segment_root.display(),
+                "failed to spawn graph organizer agent: {err}"
+            );
+        }
+    });
+}
+
+fn build_graph_organizer_prompt(thread_root: &Path, segment_root: &Path) -> String {
+    format!(
+        concat!(
+            "Organize the reset continuity graph in `{}`.\n",
+            "Read the newest raw segment at `{}` and update the graph so future fresh-context turns can recover chronology and themes without a compacted summary capsule.\n",
+            "Rules:\n",
+            "- Work only inside this graph root.\n",
+            "- Do not modify files under `segments/`.\n",
+            "- When present, use `history.json`, `rollout_items.json`, and `rollout_path.txt` as the raw archival substrate behind the notes.\n",
+            "- Update `index.md`, `timeline/overview.md`, and `themes/index.md`.\n",
+            "- Create additional notes under `timeline/` or `themes/` when useful.\n",
+            "- Use Obsidian wikilinks.\n",
+            "- Prefer chronology first, then stable themes, decisions, open loops, and unresolved contradictions.\n",
+            "- Keep notes concise, concrete, and incremental.\n"
+        ),
+        thread_root.display(),
+        segment_root.display(),
+    )
+}
+
+fn response_item_label(item: &ResponseItem) -> &'static str {
+    match item {
+        ResponseItem::Message { .. } => "message",
+        ResponseItem::Reasoning { .. } => "reasoning",
+        ResponseItem::LocalShellCall { .. } => "local-shell-call",
+        ResponseItem::FunctionCall { .. } => "function-call",
+        ResponseItem::ToolSearchCall { .. } => "tool-search-call",
+        ResponseItem::FunctionCallOutput { .. } => "function-call-output",
+        ResponseItem::CustomToolCall { .. } => "custom-tool-call",
+        ResponseItem::CustomToolCallOutput { .. } => "custom-tool-call-output",
+        ResponseItem::ToolSearchOutput { .. } => "tool-search-output",
+        ResponseItem::WebSearchCall { .. } => "web-search-call",
+        ResponseItem::ImageGenerationCall { .. } => "image-generation-call",
+        ResponseItem::GhostSnapshot { .. } => "ghost-snapshot",
+        ResponseItem::Compaction { .. } => "compaction",
+        ResponseItem::Other => "other",
+    }
+}
+
+fn pretty_json(raw: &str) -> String {
+    serde_json::from_str::<serde_json::Value>(raw)
+        .and_then(|value| serde_json::to_string_pretty(&value))
+        .unwrap_or_else(|_| raw.to_string())
+}
+
+fn sanitize_path_component(input: &str) -> String {
+    let sanitized = input
+        .chars()
+        .map(|ch| {
+            if ch.is_ascii_alphanumeric() || matches!(ch, '-' | '_') {
+                ch
+            } else {
+                '-'
+            }
+        })
+        .collect::<String>()
+        .trim_matches('-')
+        .to_string();
+    if sanitized.is_empty() {
+        "segment".to_string()
+    } else {
+        sanitized
+    }
+}
+
+fn rollout_archive_section(rollout_archive: Option<&RolloutArchive>) -> String {
+    match rollout_archive {
+        Some(archive) => format!(
+            concat!(
+                "- Raw rollout items: `rollout_items.json`\n",
+                "- Rollout source path: `{}`\n\n"
+            ),
+            archive.path.display()
+        ),
+        None => String::new(),
+    }
+}
+
+async fn load_rollout_archive(sess: &Session) -> Option<RolloutArchive> {
+    let rollout_path = sess.hook_transcript_path().await?;
+    match RolloutRecorder::get_rollout_history(rollout_path.as_path()).await {
